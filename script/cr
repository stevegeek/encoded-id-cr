#!/usr/bin/env bash
# Wrapper for crystal that sets CRYSTAL_LIBRARY_PATH so the embedded libgc is found.
# Needed because asdf 0.18 (Go-based) bypasses the upstream asdf-crystal bash wrapper.
set -euo pipefail

CRYSTAL_INSTALL="${HOME}/.asdf/installs/crystal/1.20.1"
export CRYSTAL_LIBRARY_PATH="${CRYSTAL_LIBRARY_PATH:+$CRYSTAL_LIBRARY_PATH:}${CRYSTAL_INSTALL}/embedded/lib"
exec crystal "$@"
